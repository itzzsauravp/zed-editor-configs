[
    // 1. VIM NORMAL MODE: LSP BINDS + DIAGNOSTICS
    {
        "context": "VimControl && vim_mode == normal",
        "bindings": {
            "g d": "editor::GoToDefinition",
            "space d f": "editor::GoToDefinitionSplit",
            "space d h": "editor::Hover",
            "space d d": "diagnostics::Deploy",
            "space d s": "outline::Toggle",
            "] d": "editor::GoToDiagnostic",
            "[ d": "editor::GoToPreviousDiagnostic"
        }
    },

    // 2. VIM NORMAL MODE: TABS, SPLITS, FILE TREE TOGGLE
    {
        "context": "Editor && vim_mode == normal",
        "bindings": {
            "ctrl-b": "workspace::ToggleLeftDock",
            "space e": "workspace::ToggleLeftDock",
            "shift-h": "pane::ActivatePreviousItem",
            "shift-l": "pane::ActivateNextItem",
            "shift-|": "pane::SplitRight",
            "shift--": "pane::SplitDown"
        }
    },

    // 3. EDITOR PANE NAVIGATION (all vim modes)
    //    ctrl-hjkl moves between splits only, never opens panels
    {
        "context": "Editor",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-j": "workspace::ActivatePaneDown",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-/": "terminal_panel::ToggleFocus"
        }
    },

    // 4. FILE TREE — NAVIGATION + FILE OPERATIONS
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "ctrl-b": "workspace::ToggleLeftDock",
            "space e": "workspace::ToggleLeftDock",
            "ctrl-l": "editor::ToggleFocus",
            "a": "project_panel::NewFile",
            "r": "project_panel::Rename",
            "d": ["project_panel::Trash", { "skip_prompt": false }]
        }
    },

    // 5. TERMINAL — PANE NAVIGATION + SPLITS
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-j": "workspace::ActivatePaneDown",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-b": "workspace::ToggleLeftDock",
            "ctrl-/": "workspace::ToggleBottomDock",
            "ctrl-enter": "workspace::NewTerminal",
            "alt-\\": "pane::SplitRight",
            "alt-l": "pane::SplitRight",
            "alt--": "pane::SplitDown",
            "alt-j": "pane::SplitDown"
        }
    },

    // 6. GLOBAL FALLBACKS
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-/": "terminal_panel::ToggleFocus",
            "ctrl-b": "workspace::ToggleLeftDock"
        }
    },

    // 7. VIM INSERT → NORMAL
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "j k": "vim::NormalBefore"
        }
    }
]
