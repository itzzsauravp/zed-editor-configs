// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "base_keymap": "VSCode",
    "disable_ai": true,
    "zoomed_padding": true,
    "active_pane_modifiers": {
        "border_size": 2.0,
        "inactive_opacity": 0.75
    },
    "window_decorations": "client",
    "use_system_window_tabs": false,
    "tabs": {
        "file_icons": true,
        "git_status": false
    },
    "title_bar": {
        "show_menus": false,
        "show_user_picture": false,
        "show_branch_status_icon": false
    },
    "status_bar": {
        "show_active_file": true
    },
    "project_panel": {
        "sort_order": "default",
        "sort_mode": "directories_first",
        "hide_root": false,
        "git_status_indicator": false,
        "indent_size": 25.0,
        "git_status": true,
        "folder_icons": true,
        "file_icons": true,
        "entry_spacing": "comfortable",
        "default_width": 300.0,
        "dock": "left"
    },
    "terminal": {
        "font_family": "FiraCode Nerd Font",
        "font_size": 13.0
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 1000
        }
    },
    "text_rendering_mode": "platform_default",
    "ui_font_weight": 100.0,
    "buffer_line_height": "comfortable",
    "buffer_font_weight": 100.0,
    "buffer_font_family": "FiraCode Nerd Font",
    "wsl_connections": [
        {
            "distro_name": "Ubuntu-26.04",
            "user": null,
            "projects": [
                {
                    "paths": ["/home/sauravp/yipl/pbmis-lumbini/server"]
                }
            ]
        }
    ],
    "session": {
        "trust_all_worktrees": true
    },
    "vim_mode": true,
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "ui_font_size": 15.0,
    "buffer_font_size": 13.0,
    "theme": {
        "mode": "dark",
        "light": "Ayu Mirage",
        "dark": "Rosé Pine"
    },
    "auto_install_extensions": {
        "dockerfile": true,
        "toml": true,
        "html": true,
        "sql": true,
        "prisma": true,
        "rose-pine-theme": true
    },
    "relative_line_numbers": true,
    "scroll_beyond_last_line": "off",
    "vertical_scroll_margin": 8
}
